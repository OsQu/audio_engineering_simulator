{
  "name": "aes-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Audio Engineer Simulator — dev/test web harness (reusable infra for the real UI)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "wasm": "sh build-wasm.sh",
    "wasm:watch": "cd .. && cargo watch --watch crates --shell 'sh web/build-wasm.sh'",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "format": "pnpm run format:biome && pnpm run format:svelte",
    "format:biome": "biome format --write .",
    "format:svelte": "prettier --write \"src/**/*.svelte\"",
    "lint": "biome lint .",
    "check": "biome check .",
    "fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@sveltejs/vite-plugin-svelte": "^5",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5",
    "svelte-check": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^4.1.9"
  }
}
