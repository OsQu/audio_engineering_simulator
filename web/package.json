{
  "name": "aes-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Audio Engineer Simulator — dev/test web harness (Story 3.2 Phase B; reusable infra for Epic 4)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "wasm": "sh build-wasm.sh",
    "dev": "vite",
